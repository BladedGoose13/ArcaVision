# ArcFast — variables de entorno
# Copia este archivo a .env y llena los valores

# ── IA ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── Email (opcional — para envío de reportes) ─────────────────────────────────
EMAIL_REMITENTE=tu@gmail.com
EMAIL_PASSWORD=app_password_de_gmail

# ── Agente (opcional) ─────────────────────────────────────────────────────────
# Número máximo de pasos del agente browser_use antes de abortar
AGENT_TIMEOUT_STEPS=50
