# ─────────────────────────────────────────────────────────────────────────────
# ArcaVision — variables de entorno
# Copia este archivo a .env y rellena los valores.  El .env NO se versiona.
# ─────────────────────────────────────────────────────────────────────────────

# ── IA (obligatorio) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=            # llave de Anthropic (Claude) — requerida para analizar sesiones
GROQ_API_KEY=                 # opcional — modelo alternativo

# ── Cifrado de datos financieros (recomendado) ───────────────────────────────
# Genera la llave una sola vez y guárdala bien (sin ella no podrás descifrar):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ARCAVISION_ENC_KEY=
EMAIL_CIFRAR_ADJUNTO=0         # 1 = cifrar el Excel adjunto al correo (.xlsx.enc)

# ── Email del ticket (SMTP Gmail, TLS en tránsito) ───────────────────────────
EMAIL_REMITENTE=              # tu_cuenta@gmail.com
EMAIL_PASSWORD=               # App Password de Gmail (16 chars), NO tu contraseña normal

# ── Voz (ElevenLabs TTS, opcional) ───────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Audit trail en Solana (opcional; sin esto usa fallback local) ────────────
SOLANA_PRIVATE_KEY=           # keypair del pagador (JSON array o Base58)
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Integraciones opcionales ─────────────────────────────────────────────────
MONGO_URI=                    # persistencia opcional en MongoDB
GOOGLE_CREDENTIALS_PATH=google_credentials.json   # para Google Sheets
GOOGLE_SHEET_ID=              # id de la hoja de cálculo

# ── Ajustes del agente ───────────────────────────────────────────────────────
AGENT_TIMEOUT_SEG=            # timeout por paso del agente (segundos)
