# ArcFast — Variables de entorno
# Copia este archivo como .env y llena los valores reales.
# NUNCA comitees .env al repositorio.

# ─── AI APIs ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ─── Solana Audit Trail ─────────────────────────────────────
# Keypair del pagador de transacciones en Solana.
# Genera una keypair nueva con:
#   solana-keygen new --outfile arcfast-keypair.json
# Luego copia el contenido del JSON aquí como array:
#   SOLANA_PRIVATE_KEY=[12,34,56,78,...]
# O en Base58 (output de `solana-keygen show`):
#   SOLANA_PRIVATE_KEY=5J3mBbAH58...
#
# Para devnet necesitas SOL de prueba:
#   solana airdrop 2 <TU_PUBKEY> --url devnet
SOLANA_PRIVATE_KEY=

# RPC endpoint (devnet por defecto, mainnet-beta para producción)
# Devnet:  https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com
# Helius (recomendado para producción — mayor rate limit):
#   https://mainnet.helius-rpc.com/?api-key=<TU_KEY>
SOLANA_RPC_URL=https://api.devnet.solana.com

# ─── MongoDB ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017

# ─── Email ──────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
EMAIL_FROM=arcfast@arca.mx
